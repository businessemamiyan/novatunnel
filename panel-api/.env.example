# panel-api — سرویس مستقل پنل مدیریت دسکتاپ NovaTunnel
# طبق تصمیم معماری: این سرویس فقط روی سرور رله ایران (109.122.246.148) دیپلوی می‌شود،
# کاملاً جدا از admin_api/bot که روی سرور هلند اجرا می‌شوند — به هیچ‌کدام وابسته نیست،
# مستقیم به همان دیتابیس Supabase وصل می‌شود.

# --- الزامی چون shared/config.py این‌ها را می‌خواند (حتی اگر panel-api خودش Marzban صدا نزند) ---
BOT_TOKEN=
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
MARZBAN_ADMIN_USER=unused-but-required-by-shared-config
MARZBAN_ADMIN_PASSWORD=unused-but-required-by-shared-config

# --- مخصوص panel-api ---
# رشته تصادفی قوی و مخصوص همین سرویس (هرگز مشترک با bot_token یا رمزهای دیگر نباشد)
JWT_SECRET=
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30

# آدرس(های) دقیق فرانت پنل مدیریت که مجاز به صدا زدن این API هستند (کاما-جدا)
CORS_ORIGINS=http://localhost:5173

# نام کاربری بات تلگرام بدون @ — باید دقیقاً با باتی که Telegram Login Widget در فرانت به آن اشاره می‌کند یکی باشد
TELEGRAM_BOT_USERNAME=
